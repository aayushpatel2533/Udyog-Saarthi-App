<resources>
    <!--
        Force light mode only — DayNight is replaced with Light so the app
        never switches to dark regardless of system setting.
    -->
    <style name="Theme.UdyogSaarthi" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/colorOnPrimary</item>
        <item name="colorPrimaryContainer">@color/colorPrimaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/colorOnPrimaryContainer</item>

        <!-- Secondary / accent -->
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="colorSecondaryContainer">@color/colorSecondaryContainer</item>

        <!-- Surface -->
        <item name="colorSurface">@color/colorSurface</item>
        <item name="colorSurfaceVariant">@color/colorSurfaceVariant</item>
        <item name="colorOnSurface">@color/colorOnSurface</item>
        <item name="colorOnSurfaceVariant">@color/colorOnSurfaceVariant</item>

        <!-- Background -->
        <item name="android:colorBackground">@color/colorBackground</item>

        <!-- Outline -->
        <item name="colorOutline">@color/colorOutline</item>

        <!-- Error -->
        <item name="colorError">@color/colorError</item>
        <item name="colorErrorContainer">@color/colorErrorContainer</item>

        <!-- Toolbar style -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.App.MaterialAlertDialog</item>
    </style>

    <!-- Toolbar title text appearance -->
    <style name="TextAppearance.App.Toolbar.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/colorOnPrimary</item>
        <item name="android:textSize">18sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- NavigationView: active item uses colorPrimaryContainer as indicator -->
    <style name="Widget.App.NavigationView" parent="Widget.MaterialComponents.NavigationView">
        <item name="itemIconTint">@color/nav_item_color</item>
        <item name="itemTextColor">@color/nav_item_color</item>
    </style>

    <!-- MaterialAlertDialog -->
    <style name="ThemeOverlay.App.MaterialAlertDialog"
        parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/colorPrimary</item>
    </style>
</resources>
