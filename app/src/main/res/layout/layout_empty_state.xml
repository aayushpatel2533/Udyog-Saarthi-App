<?xml version="1.0" encoding="utf-8"?>
<!--
    Reusable empty-state view.
    Include with:
        <include layout="@layout/layout_empty_state"
            android:id="@+id/layout_empty"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:visibility="gone" />
    Then set tv_empty_title / tv_empty_subtitle / iv_empty_icon from code if needed.
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="32dp">

    <ImageView
        android:id="@+id/iv_empty_icon"
        android:layout_width="88dp"
        android:layout_height="88dp"
        android:alpha="0.30"
        android:contentDescription="Empty state"
        android:src="@android:drawable/ic_menu_search" />

    <TextView
        android:id="@+id/tv_empty_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Nothing here yet"
        android:textColor="@color/colorOnSurfaceVariant"
        android:textSize="17sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_empty_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:gravity="center"
        android:text="Try adjusting your search or check back later."
        android:textColor="#BDBDBD"
        android:textSize="13sp" />

</LinearLayout>
